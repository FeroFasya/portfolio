<style>
        /* Global Styles */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: #111;
            color: #fff;
        }

        /* Navigation */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 50px;
            background-color: #111;
            position: relative;
        }

        /* Desain Button Menu */
        #menuBtn {
            font-size: 30px;
            background-color: transparent;
            border: none;
            cursor: pointer;
            color: #fff;
            transition: transform 0.3s ease, color 0.3s ease;
        }

        #menuBtn:hover {
            color: #00bcd4; /* Warna saat hover */
            transform: scale(1.1); /* Memberikan efek perbesaran */
        }

        /* Desain Navbar */
        #navbar {
            display: flex;
            flex-direction: column;
            background-color: #111;
            position: fixed;
            top: 0;
            right: 0;
            width: 250px;
            height: 100vh;
            padding-top: 60px;
            transform: translateX(100%); /* Menyembunyikan navbar saat menu off */
            transition: transform 0.4s ease-in-out;
            opacity: 0;
        }

        /* Ketika menu aktif */
        #navbar.active {
            transform: translateX(0);
            opacity: 1;
        }

        /* Tautan di Navbar */
        #navbar a {
            padding: 15px 20px;
            text-decoration: none;
            color: white;
            font-size: 20px;
            transition: background-color 0.3s ease;
        }

        /* Hover efek pada tautan */
        #navbar a:hover {
            background-color: #00bcd4; /* Warna saat hover */
        }

        /* Desain untuk <ul> */
        #menuItems {
            list-style: none; /* Menghapus bullet point */
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        /* Desain untuk tiap <li> */
        #menuItems li {
            width: 100%;
        }

        /* Desain untuk tautan <a> */
        #menuItems a {
            display: block;
            padding: 15px;
            text-decoration: none;
            color: #fff;
            font-size: 18px;
            background-color: #111;
            border-radius: 5px;
            transition: all 0.3s ease-in-out;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        }

        /* Efek saat hover */
        #menuItems a:hover {
            background-color: #00bcd4; /* Warna saat hover */
            color: white;
            transform: translateX(10px); /* Menambah efek geser */
        }

        /* Desain untuk link yang aktif */
        #menuItems a.active {
            background-color: #00bcd4;
            color: white;
            font-weight: bold;
            box-shadow: 0 4px 10px rgba(0, 188, 212, 0.4);
        }

        /* Media Query untuk Responsif (Mobile dan Tablet) */
        @media screen and (max-width: 768px) {
            /* Button Menu */
            #menuBtn {
                font-size: 28px;
                padding: 10px;
            }

            /* Navbar: membuatnya penuh di layar kecil */
            #navbar {
                width: 250px;
                height: 100vh;
                position: fixed;
                top: 0;
                left: 0;
                background-color: #333; /* Bisa ditambahkan background */
                transform: translateX(-100%); /* Menyembunyikan navbar di awal */
                opacity: 1;
                transition: transform 0.3s ease; /* Penambahan animasi saat navbar muncul */
                z-index: 99;
            }

            /* Ketika navbar aktif di layar kecil, di sebelah kiri */
            #navbar.active {
                transform: translateX(0);
            }

            /* Styling untuk setiap item di navbar */
            #navbar a {
                color: white;
                font-size: 18px;
                padding: 12px 20px;
                text-decoration: none;
                border-bottom: 1px solid #444; /* Tambahkan border untuk pemisah antar item */
                display: block;
            }

            /* Navbar item hover effect */
            #navbar a:hover {
                background-color: #555; /* Efek hover agar lebih menarik */
            }

            /* Menu items di <ul> */
            #menuItems {
                display: flex;
                flex-direction: column;
                gap: 10px;
                width: 100%;
                padding-top: 60px; /* Memberikan ruang di atas navbar */
            }

            /* Menjadikan setiap <li> responsif */
            #menuItems li {
                width: 100%;
            }

            /* Hero section adjustments for mobile */
            #hero {
                padding: 30px 10px;
            }

            #hero h1 {
                font-size: 24px; /* Ukuran font heading lebih kecil */
            }

            #hero p {
                font-size: 16px; /* Menyesuaikan ukuran font teks */
            }

            #hero img {
                width: 120px;
                height: 120px;
            }
        }

        /* Media Query untuk responsif di layar kecil (mobile) */
        @media screen and (max-width: 480px) {
            /* Adjust font size for smaller screens */
            #menuItems a {
                font-size: 16px; /* Ukuran font lebih kecil */
                padding: 12px 15px;
            }

            #menuBtn {
                font-size: 28px;
            }

            #hero h1 {
                font-size: 22px; /* Mengurangi ukuran font judul */
            }

            #hero p {
                font-size: 14px; /* Ukuran teks lebih kecil lagi untuk ponsel kecil */
            }

            #skills-section h3 {
                font-size: 18px; /* Ukuran heading skill section lebih kecil */
            }

            .skill-container input[type="range"] {
                width: 100%;
            }

            .social-icons a {
                font-size: 14px; /* Mengatur ukuran font link di footer */
                margin-left: 10px;
            }

            footer {
                padding: 15px;
            }
        }


    

        /* Hero Section */
        #hero {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 100px 50px;
            text-align: center;
            flex-direction: column;
        }

        .intro h1 {
            font-size: 4em;
            color: #fff;
        }

        .intro h1 span {
            color:  #00bcd4;
        }

        .intro p {
            margin: 20px 0;
            font-size: 1.2em;
            line-height: 1.5;
        }

        .btn {
            display: inline-block;
            padding: 10px 30px;
            margin-top: 20px;
            background-color: transparent;
            border: 2px solid  #00bcd4;
            color:  #00bcd4;
            text-decoration: none;
            border-radius: 5px;
            transition: background-color 0.3s, color 0.3s;
        }

        .btn:hover {
            background-color: #fff;
            border: 2px solid  #00bcd4;
            color:  #00bcd4;
        }

        /* Skills Section */
        #skills-section {
            text-align: left;
            max-width: 400px;
            margin: 20px auto;
        }

        .skill-container {
            margin-bottom: 15px;
        }

        /* Slider */
        input[type="range"] {
            width: 100%;
            margin: 5px 0;
            appearance: none;
            height: 10px;
            border-radius: 5px;
            background: #444;
            outline: none;
            transition: background 0.2s ease;
        }

        input[type="range"]:hover {
            background: #00bcd4;
        }

         /* Popup Container */
         #popup {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            display: none;
            z-index: 1000;
            background: rgba(0, 0, 0, 0.8);
            padding: 20px;
            border-radius: 10px;
            text-align: center;
        }

        #popup p {
            color: #fff;
            font-size: 18px;
            margin-bottom: 15px;
            font-family: Arial, sans-serif;
        }

        #popup img {
            max-width: 200px;
            height: auto;
            margin-top: 10px;
        }



        @keyframes slideDown {
            0% {
                top: -350px;
            }

            100% {
                top: 0;
            }
        }


        /* Footer */
        footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 50px;
            background-color: #111;
        }

        .social-icons a {
            color: #fff;
            text-decoration: none;
            margin-left: 20px;
            font-size: 16px;
        }

        .social-icons a:hover {
            color: #00bcd4;
        }

        /* Media Queries */
        @media (max-width: 768px) {
            header ul {
                display: none;
                flex-direction: column;
                position: absolute;
                top: 70px;
                left: 0;
                right: 0;
                background-color: #111;
                padding: 10px 0;
            }

            header ul.active {
                display: flex;
            }

            .navbar-toggler {
                display: block;
            }
        }
    </style>